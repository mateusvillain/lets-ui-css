{
  "name": "Let's UI",
  "version": "2025.10",
  "sets": {
    "global": {
      "sources": [{ "$ref": "./tokens/global/primitive.json" }, { "$ref": "./tokens/global/semantic.json" }]
    }
  },
  "modifiers": {
    "mode": {
      "default": "light",
      "contexts": {
        "light": [{ "$ref": "./tokens/global/theme/colors.light.json" }],
        "dark": [{ "$ref": "./tokens/global/theme/colors.dark.json" }]
      }
    },
    "brandColor": {
      "default": "lets-ui-light",
      "contexts": {
        "lets-ui-light": [{ "$ref": "./tokens/brand/lets-ui/colors.light.json" }],
        "lets-ui-dark": [{ "$ref": "./tokens/brand/lets-ui/colors.dark.json" }]
      }
    },
    "brandFoundation": {
      "default": "lets-ui",
      "contexts": {
        "lets-ui": [{ "$ref": "./tokens/brand/lets-ui/foundation.json" }]
      }
    }
  },
  "resolutionOrder": [{ "$ref": "#/sets/global" }, { "$ref": "#/modifiers/mode" }, { "$ref": "#/modifiers/brandFoundation" }, { "$ref": "#/modifiers/brandColor" }]
}
