{
  "name": "lets-ui",
  "private": true,
  "version": "0.19.0",
  "description": "Let's UI monorepo",
  "packageManager": "pnpm@10.8.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateusvillain/lets-ui-css.git"
  },
  "license": "MIT",
  "author": {
    "name": "Mateus Villain",
    "email": "mateus@mateusvillain.com",
    "url": "https://mateusvillain.com"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/mateusvillain/lets-ui-css/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm run lint:css && pnpm run lint:md",
    "lint:css": "stylelint \"**/*.{css,scss}\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "pnpm run build-storybook && gh-pages -b storybook -d storybook-static",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,css,scss,json,md}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/html-vite": "^10.1.11",
    "@terrazzo/cli": "^2.0.0-beta.4",
    "@terrazzo/plugin-css": "^2.0.0-beta.4",
    "@terrazzo/plugin-sass": "^2.0.0-beta.4",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "cssnano": "^7.1.2",
    "eslint": "^9.39.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.20.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.7.4",
    "sass": "^1.87.0",
    "storybook": "^10.1.11",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-scss": "^6.14.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "lets-ui-icons": "^0.1.0"
  }
}
